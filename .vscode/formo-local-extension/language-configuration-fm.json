{
  "comments": {
    "lineComment": "//",
    "blockComment": [
      "/*",
      "*/"
    ]
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "<",
      ">"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "(",
      "close": ")",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "[",
      "close": "]",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "comment"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "\"",
      "\""
    ]
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([A-Za-z_][A-Za-z0-9_.-]*)",
  "indentationRules": {
    "increaseIndentPattern": "^((?!//).)*(\\{[^\"']*)$",
    "decreaseIndentPattern": "^\\s*\\}.*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*.*\\{\\s*$",
      "afterText": "^\\s*\\}\\s*$",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "^\\s*.*\\{\\s*$",
      "action": {
        "indent": "indent"
      }
    }
  ]
}
