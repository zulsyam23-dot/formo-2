{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Formo FL",
  "scopeName": "source.formo.fl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#calls"
    },
    {
      "include": "#stateKeys"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.formo",
          "match": "//.*$"
        },
        {
          "name": "comment.block.formo",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.formo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.formo",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "entity.name.type.module.formo",
          "match": "(?<=\\bmodule\\s+)[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.logic.formo",
          "match": "(?<=\\blogic\\s+)[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.logic.formo",
          "match": "(?<=\\bservice\\s+)[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.logic.formo",
          "match": "(?<=\\bcontract\\s+)[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.logic.formo",
          "match": "(?<=\\badapter\\s+)[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.logic.formo",
          "match": "(?<=\\benum\\s+)[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.logic.formo",
          "match": "(?<=\\bstruct\\s+)[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.logic.formo",
          "match": "(?<=\\btype\\s+)[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.function.formo",
          "match": "(?<=\\bfunction\\s+)[a-z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.function.event.formo",
          "match": "(?<=\\bevent\\s+)[a-z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.type.alias.formo",
          "match": "(?<=\\bas\\s+)[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.formo",
          "match": "\\b(module|use|as|logic|service|contract|adapter|state|event|function|enum|struct|type)\\b"
        },
        {
          "name": "keyword.control.formo",
          "match": "\\b(if|for|while|match|try|catch|platform|web|desktop)\\b"
        },
        {
          "name": "support.function.formo",
          "match": "\\b(call|set|emit|throw|return|break|continue)\\b"
        },
        {
          "name": "storage.type.formo",
          "match": "\\b(bool|string|int|float|number|boolean)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "meta.typed-field.formo",
          "match": "(\\b[a-zA-Z_][A-Za-z0-9_]*\\s*:\\s*)([A-Za-z][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "variable.other.state-key.formo"
            },
            "2": {
              "name": "storage.type.formo"
            }
          }
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "meta.call-target.formo",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\.([a-z][A-Za-z0-9_]*(?:\\.[a-z][A-Za-z0-9_]*)*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.alias.formo"
            },
            "2": {
              "name": "support.function.call-path.formo"
            }
          }
        }
      ]
    },
    "stateKeys": {
      "patterns": [
        {
          "name": "variable.other.state-key.formo",
          "match": "\\b[a-z][A-Za-z0-9_]*(?=\\s*[:=])"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.formo",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.formo",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.formo",
          "match": "==|!=|<=|>=|&&|\\|\\||[=+\\-*/%<>]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.formo",
          "match": ";"
        },
        {
          "name": "punctuation.section.block.formo",
          "match": "[{}()]"
        }
      ]
    }
  }
}
